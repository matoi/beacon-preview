  (save-excursion
    (beginning-of-line)
    (when (beacon-preview--markdown-paragraph-line-p)
      (while (and (not (bobp))
                  (progn
                    (forward-line -1)
                    (beacon-preview--markdown-paragraph-line-p)))
        nil)
      (unless (beacon-preview--markdown-paragraph-line-p)
        (forward-line 1))
