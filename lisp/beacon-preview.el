        (while (and (not found) (not (eobp)))
          (when (looking-at "^[ 	]*\\(?:[-+]\\|[0-9]+[.)]\\)[ 	]+\\S-")
            (setq count (1+ count))
            (when (= (line-beginning-position) target)
              (setq found count)))
